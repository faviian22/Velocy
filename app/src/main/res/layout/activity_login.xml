<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F9FC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <!-- LOGO AREA -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="64dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_logo_hex">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/baseline_directions_bike_24"
                app:tint="#2563EB"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VELOCY"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.3"
            android:textColor="#0F172A"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sistem Monitoring Kendaraan"
            android:textSize="12sp"
            android:letterSpacing="0.15"
            android:textColor="#64748B"
            android:layout_marginBottom="48dp"/>

        <!-- FORM CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Divider line top -->
                <View
                    android:layout_width="48dp"
                    android:layout_height="2dp"
                    android:background="#2563EB"
                    android:layout_marginBottom="28dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selamat datang!"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Masuk untuk melanjutkan"
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:layout_marginBottom="28dp"/>

                <!-- Email Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMAIL"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:textColor="#2563EB"
                    android:layout_marginBottom="8dp"/>

                <!-- Email Input -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_input_dark"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="16dp"
                        android:src="@android:drawable/ic_dialog_email"
                        app:tint="#94A3B8"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Masukkan email"
                        android:inputType="textEmailAddress"
                        android:textSize="14sp"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:paddingStart="12dp"
                        android:paddingEnd="16dp"
                        android:background="@null"/>
                </LinearLayout>

                <!-- Password Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KATA SANDI"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:textColor="#2563EB"
                    android:layout_marginBottom="8dp"/>

                <!-- Password Input -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_input_dark"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="32dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="16dp"
                        android:src="@android:drawable/ic_lock_lock"
                        app:tint="#94A3B8"/>

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Masukkan kata sandi"
                        android:inputType="textPassword"
                        android:textSize="14sp"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:paddingStart="12dp"
                        android:background="@null"/>

                    <ImageView
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="12dp"
                        android:src="@drawable/ic_eye"
                        app:tint="#94A3B8"/>
                </LinearLayout>

                <!-- Login Button -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="#2563EB">

                    <Button
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Masuk"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:backgroundTint="@android:color/transparent"
                        android:stateListAnimator="@null"/>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Daftar Link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum punya akun? "
                android:textSize="13sp"
                android:textColor="#64748B"/>

            <TextView
                android:id="@+id/tvRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daftar"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#2563EB"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>